{
  "manifest_version": 3,
  "name": "Browser Video OCR",
  "version": "0.1.0",
  "description": "Minimal Chrome extension base.",
  "permissions": ["storage"],
  "host_permissions": ["https://vision.googleapis.com/*"],
  "action": {
    "default_title": "Browser Video OCR",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
